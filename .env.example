# Telegram Bot
BOT_TOKEN=your_bot_token
LOG_CHAT_ID=your_log_chat_id
SUPERUSERS=123456789,987654321
ALLOWED_GROUPS=-100123456789,-100987654321

# Web Server (must be HTTPS for Telegram Mini Web Apps)
WEB_BASE_URL=https://yourdomain.com
WEB_HOST=0.0.0.0
WEB_PORT=8443

# Database
DB_PATH=approverbot.db

# Fingerprint Matching
SIMILARITY_THRESHOLD=0.75
DEVICE_ID_AUTO_FLAG=true
AUTO_DECLINE_ON_MATCH=false
PENDING_REQUEST_TTL_MINUTES=30
